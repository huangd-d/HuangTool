{
  "name": "electron-doc",
  "version": "1.0.0",
  "description": "综合工具平台",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "src/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "set NODE_ENV=development && electron .",
    "build": "npm run build:web && electron-builder",
    "build:web": "cd ../web && npm run build && cd ../electron"
  },
  "dependencies": {
    "electron": "^41.1.1"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1",
    "electron-reloader": "^1.2.3"
  },
  "build": {
    "appId": "com.electron.docapp",
    "productName": "综合工具平台",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "docs/**/*",
      "../web/dist/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
